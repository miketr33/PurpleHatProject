@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<div class="alert alert-info">
    <strong>Purpose:</strong> This page helps us quickly confirm that Blazor interaction is functioning as expected. For
    debugging purposes. This page is for development/demo use only and should be removed before production. 
</div>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
