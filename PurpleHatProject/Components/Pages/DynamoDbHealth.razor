@page "/dynamodb-health"
@rendermode InteractiveServer
@using Amazon.DynamoDBv2
@using Amazon.DynamoDBv2.Model
@inject IAmazonDynamoDB DynamoDb

<PageTitle>DynamoDB Health</PageTitle>

<h1>DynamoDB Health Check</h1>

<p class="text-muted">
    This page verifies that DynamoDB is reachable and working correctly.
    It tests the connection, creates a test table if needed, then lets you write and read back entries
    to confirm full round-trip functionality.
    This page is for development/demo use only and should be removed before production.
</p>

<div class="alert alert-info">
    <strong>Note:</strong> In development this connects to DynamoDB Local running in Docker on port 8000.
    Data persists only while the Docker container is running. In production this would connect to the real
    AWS DynamoDB service where data is durable by default.
</div>

<hr />

<h4>Connection Status</h4>

@if (_connectionStatus is null)
{
    <p><em>Checking...</em></p>
}
else if (_connectionStatus == true)
{
    <span class="badge bg-success">Connected</span>
    <span class="ms-2 text-muted">Table: @TableName (@_tableStatus)</span>
}
else
{
    <span class="badge bg-danger">Failed</span>
    <p class="text-danger mt-2">@_errorMessage</p>
}

<hr />

<h4>Round-Trip Test</h4>

<button class="btn btn-primary" @onclick="WriteTestEntry" disabled="@(_connectionStatus != true)">
    Write Test Entry
</button>

@if (_entries.Count > 0)
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Id</th>
                <th>Created At</th>
                <th>Message</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in _entries)
            {
                <tr>
                    <td>@entry["Id"].S</td>
                    <td>@entry["CreatedAt"].S</td>
                    <td>@entry["Message"].S</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (_connectionStatus == true)
{
    <p class="mt-3 text-muted">No entries yet. Click the button to write one.</p>
}

@code {
    private const string TableName = "HealthCheck";

    private bool? _connectionStatus;
    private string? _errorMessage;
    private string _tableStatus = "";
    private List<Dictionary<string, AttributeValue>> _entries = [];

    protected override async Task OnInitializedAsync()
    {
        await CheckConnection();
    }

    private async Task CheckConnection()
    {
        try
        {
            await EnsureTableExists();
            _connectionStatus = true;
            await LoadEntries();
        }
        catch (Exception ex)
        {
            _connectionStatus = false;
            _errorMessage = ex.Message;
        }
    }

    private async Task EnsureTableExists()
    {
        var tables = await DynamoDb.ListTablesAsync();
        if (tables.TableNames.Contains(TableName))
        {
            _tableStatus = "exists";
            return;
        }

        await DynamoDb.CreateTableAsync(new CreateTableRequest
        {
            TableName = TableName,
            KeySchema = [new KeySchemaElement("Id", KeyType.HASH)],
            AttributeDefinitions = [new AttributeDefinition("Id", ScalarAttributeType.S)],
            BillingMode = BillingMode.PAY_PER_REQUEST
        });
        _tableStatus = "created";
    }

    private async Task LoadEntries()
    {
        var response = await DynamoDb.ScanAsync(new ScanRequest
        {
            TableName = TableName,
            Limit = 10
        });
        _entries = response.Items
            .OrderByDescending(i => i["CreatedAt"].S)
            .ToList();
    }

    private async Task WriteTestEntry()
    {
        var count = (await DynamoDb.ScanAsync(new ScanRequest { TableName = TableName })).Count;

        await DynamoDb.PutItemAsync(new PutItemRequest
        {
            TableName = TableName,
            Item = new Dictionary<string, AttributeValue>
            {
                ["Id"] = new(Guid.NewGuid().ToString()),
                ["CreatedAt"] = new(DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss")),
                ["Message"] = new($"Test entry #{count + 1}")
            }
        });

        await LoadEntries();
    }
}
