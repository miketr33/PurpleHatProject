@page "/db-health"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PurpleHatProject.Data
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>DB Health</PageTitle>

<h1>Database Health Check</h1>

<p class="text-muted">
    This page verifies that the SQLite database is reachable and working correctly.
    It tests the connection, then lets you write and read back test entries to confirm full round-trip functionality.
    This page is for development/demo use only and should be removed before production.
</p>

<div class="alert alert-info">
    <strong>Note:</strong> SQLite stores data in a local file on the server. If the app or container is
    restarted, the database file is recreated via migrations and all previous data will be lost. This is
    expected behaviour for this setup — persistent storage would require a managed database service but 
    for simplicity and cost reasons we are using SQLite for the time being.
</div>

<hr />

<h4>Connection Status</h4>

@if (_connectionStatus is null)
{
    <p><em>Checking...</em></p>
}
else if (_connectionStatus == true)
{
    <span class="badge bg-success">Connected</span>
}
else
{
    <span class="badge bg-danger">Failed</span>
    <p class="text-danger mt-2">@_errorMessage</p>
}

<hr />

<h4>Round-Trip Test</h4>

<button class="btn btn-primary" @onclick="WriteTestEntry" disabled="@(_connectionStatus != true)">
    Write Test Entry
</button>

@if (_entries.Count > 0)
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Id</th>
                <th>Created At</th>
                <th>Message</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in _entries)
            {
                <tr>
                    <td>@entry.Id</td>
                    <td>@entry.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@entry.Message</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (_connectionStatus == true)
{
    <p class="mt-3 text-muted">No entries yet. Click the button to write one.</p>
}

@code {
    private bool? _connectionStatus;
    private string? _errorMessage;
    private List<HealthCheckEntry> _entries = [];

    protected override async Task OnInitializedAsync()
    {
        await CheckConnection();
    }

    private async Task CheckConnection()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await db.Database.CanConnectAsync();
            _connectionStatus = true;
            _entries = await db.HealthCheckEntries
                .OrderByDescending(e => e.CreatedAt)
                .Take(10)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            _connectionStatus = false;
            _errorMessage = ex.Message;
        }
    }

    private async Task WriteTestEntry()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        db.HealthCheckEntries.Add(new HealthCheckEntry
        {
            CreatedAt = DateTime.UtcNow,
            Message = $"Test entry #{await db.HealthCheckEntries.CountAsync() + 1}"
        });
        await db.SaveChangesAsync();

        _entries = await db.HealthCheckEntries
            .OrderByDescending(e => e.CreatedAt)
            .Take(10)
            .ToListAsync();
    }
}
