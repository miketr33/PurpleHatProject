@page "/music"
@rendermode InteractiveServer
@using Microsoft.JSInterop
@using PurpleHatProject.Models
@using PurpleHatProject.Services
@inject ITrackService TrackService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Music Player</PageTitle>

<h1>Music Player</h1>

<div class="track-list">
    <table class="table track-table">
        <thead>
            <tr>
                <th class="col-num">#</th>
                <th class="col-art"></th>
                <th>Title</th>
                <th>Artist</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var track in _tracks)
            {
                var isPlaying = track.Id == _currentTrackId;
                <tr class="@(isPlaying ? "track-row active" : "track-row")" @onclick="() => SelectTrack(track.Id)">
                    <td class="col-num">
                        @if (isPlaying)
                        {
                            <span class="eq-bars" title="Now playing">
                                <span class="eq-bar"></span>
                                <span class="eq-bar"></span>
                                <span class="eq-bar"></span>
                            </span>
                        }
                        else
                        {
                            @track.Id
                        }
                    </td>
                    <td class="col-art">
                        <div class="track-art">
                            @if (track.ArtworkUrl is not null)
                            {
                                <img src="@track.ArtworkUrl" alt="@track.Title album art" />
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55C7.79 13 6 14.79 6 17s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                                </svg>
                            }
                        </div>
                    </td>
                    <td class="track-title">@track.Title</td>
                    <td class="text-muted">@track.Artist</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="player-bar">
    <div class="player-now-playing">
        @if (CurrentTrack is not null)
        {
            <div class="album-art">
                @if (CurrentTrack.ArtworkUrl is not null)
                {
                    <img src="@CurrentTrack.ArtworkUrl" alt="@CurrentTrack.Title album art" />
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55C7.79 13 6 14.79 6 17s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                    </svg>
                }
            </div>
            <div class="now-playing-info">
                <span class="now-playing-title">@CurrentTrack.Title</span>
                <span class="now-playing-artist">@CurrentTrack.Artist</span>
            </div>
        }
    </div>

    <div class="player-controls">
        <button class="control-btn" @onclick="PreviousTrack" title="Previous">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/>
            </svg>
        </button>
        <button class="control-btn play-btn" @onclick="TogglePlayPause" title="@(_isPlaying ? "Pause" : "Play")">
            @if (_isPlaying)
            {
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M6 19h4V5H6zm8-14v14h4V5z"/>
                </svg>
            }
            else
            {
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z"/>
                </svg>
            }
        </button>
        <button class="control-btn" @onclick="NextTrack" title="Next">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6z"/>
            </svg>
        </button>
    </div>

    <div class="player-volume">
        <button class="control-btn volume-mute-btn" @onclick="ToggleMute" title="@(IsMuted ? "Unmute" : "Mute")">
            @if (IsMuted)
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3 3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4 9.91 6.09 12 8.18V4z"/>
                </svg>
            }
            else
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
                </svg>
            }
        </button>
        <input type="range" min="0" max="100" value="@_volume" @oninput="OnVolumeChange" class="volume-slider" />
    </div>
</div>

@code {
    private int? _currentTrackId;
    private bool _isPlaying;
    private bool _isMuted;
    private int _volume = 60;
    private int _volumeBeforeMute = 60;
    private IReadOnlyList<Track> _tracks = [];
    private IJSObjectReference? _audioModule;
    private DotNetObjectReference<MusicPlayer>? _dotNetRef;

    private bool IsMuted => _isMuted || _volume == 0;

    private Track? CurrentTrack => _currentTrackId is not null
        ? _tracks.FirstOrDefault(t => t.Id == _currentTrackId)
        : null;

    protected override void OnInitialized()
    {
        _tracks = TrackService.GetTracks();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _audioModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/audioPlayer.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            await _audioModule.InvokeVoidAsync("init", _dotNetRef);
        }
    }

    private async Task SelectTrack(int trackId)
    {
        _currentTrackId = trackId;
        _isPlaying = true;
        await PlayCurrentTrack();
    }

    private async Task TogglePlayPause()
    {
        if (_currentTrackId is null || _audioModule is null) return;

        if (_isPlaying)
        {
            await _audioModule.InvokeVoidAsync("pause");
            _isPlaying = false;
        }
        else
        {
            await _audioModule.InvokeVoidAsync("resume");
            _isPlaying = true;
        }
    }

    private async Task NextTrack()
    {
        if (_currentTrackId is null) return;
        var currentIndex = _tracks.ToList().FindIndex(t => t.Id == _currentTrackId);
        var nextIndex = (currentIndex + 1) % _tracks.Count;
        _currentTrackId = _tracks[nextIndex].Id;
        _isPlaying = true;
        await PlayCurrentTrack();
    }

    private async Task PreviousTrack()
    {
        if (_currentTrackId is null) return;
        var currentIndex = _tracks.ToList().FindIndex(t => t.Id == _currentTrackId);
        var prevIndex = (currentIndex - 1 + _tracks.Count) % _tracks.Count;
        _currentTrackId = _tracks[prevIndex].Id;
        _isPlaying = true;
        await PlayCurrentTrack();
    }

    private async Task PlayCurrentTrack()
    {
        if (_audioModule is null || CurrentTrack is null) return;
        var effectiveVolume = IsMuted ? 0 : _volume;
        await _audioModule.InvokeVoidAsync("play", CurrentTrack.AudioUrl, effectiveVolume);
    }

    private async Task ToggleMute()
    {
        if (_audioModule is null) return;

        if (IsMuted)
        {
            _isMuted = false;
            _volume = _volumeBeforeMute > 0 ? _volumeBeforeMute : 60;
            await _audioModule.InvokeVoidAsync("setVolume", _volume);
        }
        else
        {
            _volumeBeforeMute = _volume;
            _isMuted = true;
            await _audioModule.InvokeVoidAsync("setVolume", 0);
        }
    }

    private async Task OnVolumeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var vol))
        {
            _volume = vol;
            _isMuted = false;
            if (_audioModule is not null)
                await _audioModule.InvokeVoidAsync("setVolume", _volume);
        }
    }

    [JSInvokable]
    public async Task OnTrackEnded()
    {
        await NextTrack();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_audioModule is not null)
        {
            await _audioModule.InvokeVoidAsync("dispose");
            await _audioModule.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }
}
